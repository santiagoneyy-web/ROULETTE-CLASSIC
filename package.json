{
  "name": "clasi-roulette",
  "version": "1.1.0",
  "main": "server.js",
  "scripts": {
    "start": "node start.js",
    "api": "node server.js",
    "stack": "node start.js",
    "stack:v2": "node start_v2.js",
    "crawler": "node crawler.js --api http://127.0.0.1:3000/api/spin",
    "crawler:v2": "node crawler_v2.js",
    "stack:render": "concurrently -n API,CASINO -c blue,green \"node server.js\" \"node crawler_v2.js --source casinoorg --interval 3000\"",
    "crawler:casinoorg": "node crawler_v2.js --source casinoorg",
    "crawler:gc": "node crawler_v2.js --source gamblingcounting",
    "diagnose": "node test_crawler_diagnosis.js",
    "postinstall": "npx puppeteer browsers install chrome",
    "build": "npm install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.6.0",
    "concurrently": "^8.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "puppeteer": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.32.6",
    "tesseract.js": "^5.0.0"
  }
}
